Interview_Time","defaultMatch":false,"canBeUsedToMatch":true},{"id":"row_number","type":"number","display":true,"removed":true,"readOnly":true,"required":false,"displayName":"row_number","defaultMatch":false,"canBeUsedToMatch":true}],"mappingMode":"defineBelow","matchingColumns":["Email Address"],"attemptToConvertTypes":false,"convertFieldsToString":false},"options":{},"operation":"update","sheetName":{"__rl":true,"mode":"list","value":358702502,"cachedResultUrl":"https://docs.google.com/spreadsheets/d/1NBsshSSl7LVfn-TnP8JyhcoLTl7g0YTsvrpMZygN670/edit#gid=358702502","cachedResultName":"Form Responses 1"},"documentId":{"__rl":true,"mode":"list","value":"1NBsshSSl7LVfn-TnP8JyhcoLTl7g0YTsvrpMZygN670","cachedResultUrl":"https://docs.google.com/spreadsheets/d/1NBsshSSl7LVfn-TnP8JyhcoLTl7g0YTsvrpMZygN670/edit?usp=drivesdk","cachedResultName":"Athena Jobs"}},"credentials":{"googleSheetsOAuth2Api":{"id":"pqhCUJdTO98td28J","name":"Google Sheets account"}},"typeVersion":4.7},{"id":"c6a3b863-f7b8-4908-ac12-d86c815be627","name":"Sticky Note8","type":"n8n-nodes-base.stickyNote","position":[-1104,1104],"parameters":{"color":7,"width":416,"height":416,"content":"## 👁️ HR Decision Watcher\n\nPolls the sheet every minute watching for changes to \nthe HR_Decision column. The IF node ensures the email \nonly sends when HR_Decision is filled AND Email_Status \nis not already \"Sent\" — preventing any duplicate \nemails.\n\n→ HR must type exactly:\n  \"Send Invite\" — to invite the candidate\n  \"Send Rejection\" — to reject the candidate"},"typeVersion":1},{"id":"5f8dad61-a7f6-44b4-b311-14abd9ae33e4","name":"Sticky Note9","type":"n8n-nodes-base.stickyNote","position":[-672,1040],"parameters":{"color":7,"width":480,"height":608,"content":"## ✉️ Email Template Builder\n\nRoutes to the correct email template based on the HR \ndecision. The invitation email includes a pre-filled \nCalendly link with the candidate's name and email. \nThe rejection email delivers a respectful, encouraging \nmessage.\n\n⚠️→ Replace YOUR_CALENDLY_LINK in the Invitation \n  Message node with your actual Calendly URL."},"typeVersion":1},{"id":"41d22646-afa4-4f21-a6a3-c0e58ff9fa6f","name":"Sticky Note10","type":"n8n-nodes-base.stickyNote","position":[-176,1024],"parameters":{"color":7,"width":416,"height":624,"content":"## 📬 Send & Confirm\n\nSends the email via Gmail and immediately writes \n\"Sent\" to the Email_Status column in the sheet. \nThis status flag prevents the workflow from sending \nthe same email twice if the sheet is updated again."},"typeVersion":1},{"id":"4d763aa2-3458-4bd9-bb21-37de8679e833","name":"Sticky Note11","type":"n8n-nodes-base.stickyNote","position":[-1120,944],"parameters":{"color":7,"width":1408,"height":736,"content":"\n\n# #2 HR Decision & Email Sender"},"typeVersion":1},{"id":"166f7bf6-4fee-4f0d-8de8-cf8df34d4c1e","name":"Interview Event Received","type":"n8n-nodes-base.calendlyTrigger","position":[480,1456],"webhookId":"be877e16-fc6d-4274-8383-b4e2b0852580","parameters":{"events":["invitee.created","invitee.canceled"],"authentication":"oAuth2"},"credentials":{"calendlyOAuth2Api":{"id":"4AZMcjhwiI6LSL58","name":"Calendly account 2"}},"typeVersion":1},{"id":"ae9d9bc2-58b3-4362-8abe-fbe86168ebed","name":"Route by Event Type","type":"n8n-nodes-base.switch","position":[704,1456],"parameters":{"rules":{"values":[{"outputKey":"event created","conditions":{"options":{"version":3,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"5540bc63-b47c-4a17-ae56-74021b4e36fd","operator":{"type":"string","operation":"equals"},"leftValue":"={{ $json.event }}","rightValue":"invitee.created"}]},"renameOutput":true},{"outputKey":"event canceled","conditions":{"options":{"version":3,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"f3c8cfa1-a06a-410f-a72f-f48fa8778d13","operator":{"name":"filter.operator.equals","type":"string","operation":"equals"},"leftValue":"={{ $json.event }}","rightValue":"invitee.canceled"}]},"renameOutput":true}]},"options":{}},"typeVersion":3.4},{"id":"0ade49ee-c733-4d18-9103-50ad73d0e23b","name":"Extract Booking Details","type":"n8n-nodes-base.set","position":[944,1168],"parameters":{"options":{},"assignments":{"assignments":[{"id":"e9a24d0d-6eaf-4fe2-8f3b-3849414ca277","name":"email","type":"string","value":"={{ $json.payload.email }}"},{"id":"602bbc2d-f409-4cda-b551-2e2eda41b5e9","name":"start_time","type":"string","value":"={{ $json.payload.scheduled_event.start_time }}"}]}},"typeVersion":3.4},{"id":"23682699-0bbe-43fa-81e9-d7362b60916c","name":"Format Interview Time","type":"n8n-nodes-base.dateTime","position":[1184,1168],"parameters":{"date":"={{ $json.start_time }}","format":"custom","options":{"timezone":true},"operation":"formatDate","customFormat":"hh:mm a (dd/MM/yyyy)","outputFieldName":"pakistanTime"},"typeVersion":2},{"id":"302d3d24-f98e-4bcb-875b-266fd3025b35","name":"Log Interview Time","type":"n8n-nodes-base.googleSheets","position":[1408,1168],"parameters":{"columns":{"value":{"Email Address":"={{ $('Extract Booking Details').item.json.email }}","Interview_Time":"={{ $json.pakistanTime }}"},"schema":[{"id":"Timestamp","type":"string","display":true,"removed":true,"required":false,"displayName":"Timestamp","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Email Address","type":"string","display":true,"removed":false,"required":false,"displayName":"Email Address","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Full Name  ","type":"string","display":true,"removed":true,"required":false,"displayName":"Full Name  ","defaultMatch":false,"canBeUsedToMatch":true},{"id":"WhatsApp / Phone Number ","type":"string","display":true,"removed":true,"required":false,"displayName":"WhatsApp / Phone Number ","defaultMatch":false,"canBeUsedToMatch":true},{"id":"City / Location  ","type":"string","display":true,"removed":true,"required":false,"displayName":"City / Location  ","defaultMatch":