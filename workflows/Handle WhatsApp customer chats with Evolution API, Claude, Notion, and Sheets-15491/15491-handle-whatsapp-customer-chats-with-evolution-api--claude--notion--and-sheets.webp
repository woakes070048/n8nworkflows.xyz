des-base.telegram","notes":"Get your Chat ID by sending a message to @userinfobot on Telegram.\nSet it directly in this node or use an n8n environment variable.","position":[6032,2496],"webhookId":"ddc7a759-d904-4869-b447-4941fa6e878b","parameters":{"text":"=🚨 *WhatsApp — Customer needs attention*\n\n👤 *Name:* {{ $json.username }}\n📱 *Phone:* {{ $json.user_id }}\n📩 *Type:* {{ $json.message_type }}\n🎯 *Intent:* {{ $json.intent }}\n\n*Message:*\n{{ $json.message }}\n\n*BOT RESPONSE:*\n{{ $json.response }}\n\n---\n🕐 {{ $json.timestamp }}","chatId":"=ADD_YOUR_TELEGRAM_CHAT_ID","additionalFields":{"parse_mode":"HTML","appendAttribution":false}},"typeVersion":1.2},{"id":"b3d554f9-9420-431b-84bc-1e94edf92844","name":"Wait1","type":"n8n-nodes-base.wait","position":[4224,2592],"webhookId":"ef12602b-f50d-4112-ade4-a5b9e926ee39","parameters":{"amount":10},"typeVersion":1.1},{"id":"c8534b1c-864c-4c16-b0cf-78d7350e21f3","name":"Format Cleaner1","type":"n8n-nodes-base.code","position":[4752,2568],"parameters":{"mode":"runOnceForEachItem","jsCode":"// Strip markdown formatting from AI response\nlet text = $input.item.json.output || '';\n\n// Remove bold/italic\ntext = text.replace(/\\*\\*(.*?)\\*\\*/g, '$1');\ntext = text.replace(/\\*(.*?)\\*/g, '$1');\ntext = text.replace(/_(.*?)_/g, '$1');\n\n// Replace em dashes with comma\ntext = text.replace(/ — /g, ', ');\ntext = text.replace(/—/g, ', ');\n\n// Remove markdown headers\ntext = text.replace(/^#{1,3}\\s+/gm, '');\n\n// Clean up extra blank lines (max 1)\ntext = text.replace(/\\n{3,}/g, '\\n\\n');\n\nreturn { json: { ...$input.item.json, output: text.trim() } };\n"},"typeVersion":2},{"id":"4eca12e6-2f1b-4820-beca-b4ec624ddb8b","name":"Skip Event1","type":"n8n-nodes-base.if","position":[1008,2464],"parameters":{"options":{},"conditions":{"options":{"version":3,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"or","conditions":[{"id":"59df61c1-eed2-452c-bbdb-ee44dcfe22d4","operator":{"type":"boolean","op